#!/usr/bin/env bash
set -euo pipefail

SKILLS_DIR="${SKILLS_DIR:-$(cd "$(dirname "$0")" && pwd)}"
AGENT="${1:-all}"

case "$AGENT" in
    claude|codex|all) ;;
    *) echo "error: unknown agent '$AGENT'. Use: claude, codex, or all" >&2; exit 1 ;;
esac

if ! git -C "$(pwd)" rev-parse --git-dir >/dev/null 2>&1; then
    echo "error: not inside a git repository. Run from your project root." >&2
    exit 1
fi

if [[ ! -d "$SKILLS_DIR" ]]; then
    echo "error: skills repo not found at $SKILLS_DIR" >&2
    printf 'Bootstrap: git clone git@github.com:<you>/skills.git ~/skills\n' >&2
    exit 1
fi

if ! git -C "$SKILLS_DIR" pull --ff-only >/dev/null 2>&1; then
    echo "warning: git pull --ff-only failed, continuing with local copy" >&2
fi

install_claude=false
install_codex=false
case "$AGENT" in
    claude) install_claude=true ;;
    codex)  install_codex=true ;;
    all)    install_claude=true; install_codex=true ;;
esac

CLAUDE_SKILLS_DIR="$(pwd)/.claude/skills"
CODEX_SKILLS_DIR="$(pwd)/.agents/skills"

[[ "$install_claude" == true ]] && mkdir -p "$CLAUDE_SKILLS_DIR"
[[ "$install_codex"  == true ]] && mkdir -p "$CODEX_SKILLS_DIR"

for skill_dir in "$SKILLS_DIR/skills"/*/; do
    [[ -d "$skill_dir" ]] || continue
    skill_name="$(basename "$skill_dir")"
    skill_md="$skill_dir/SKILL.md"

    if [[ ! -f "$skill_md" ]]; then
        echo "warning: $skill_name has no SKILL.md, skipping" >&2
        continue
    fi

    if [[ "$install_claude" == true ]]; then
        rm -rf "${CLAUDE_SKILLS_DIR:?}/$skill_name"
        cp -r "${skill_dir%/}" "$CLAUDE_SKILLS_DIR/"
    fi

    if [[ "$install_codex" == true ]]; then
        rm -rf "${CODEX_SKILLS_DIR:?}/$skill_name"
        cp -r "${skill_dir%/}" "$CODEX_SKILLS_DIR/"
    fi
done

GIT_DIR="$(git -C "$(pwd)" rev-parse --git-dir)"
EXCLUDE_FILE="$GIT_DIR/info/exclude"
mkdir -p "$GIT_DIR/info"
touch "$EXCLUDE_FILE"

_exclude_if_missing() {
    local entry="$1"
    grep -qxF "$entry" "$EXCLUDE_FILE" || echo "$entry" >> "$EXCLUDE_FILE"
}

if ! grep -qF "# Agent skills" "$EXCLUDE_FILE"; then
    printf '\n# Agent skills (managed by %s/install)\n' "$SKILLS_DIR" >> "$EXCLUDE_FILE"
fi
[[ "$install_claude" == true ]] && _exclude_if_missing ".claude/"
[[ "$install_codex"  == true ]] && _exclude_if_missing ".agents/"

echo "Done."
